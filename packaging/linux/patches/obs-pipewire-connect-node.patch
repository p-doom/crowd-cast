+/* crowd-cast: connect directly to an existing PipeWire node (e.g. one produced by
+ * org.gnome.Mutter.ScreenCast RecordWindow/RecordMonitor), bypassing the xdg-desktop-portal
+ * session and its window/screen picker. Mirrors on_pipewire_remote_opened_cb, but connects to
+ * the default PipeWire daemon (fd -1) instead of a portal-provided fd, and uses the node id
+ * already stored in capture->pipewire_node. */
+static void connect_to_node_directly(struct screencast_portal_capture *capture)
+{
+	struct obs_pipewire_connect_stream_info connect_info;
+
+	capture->obs_pw = obs_pipewire_connect_fd(-1, NULL, NULL);
+	if (!capture->obs_pw)
+		return;
+
+	connect_info = (struct obs_pipewire_connect_stream_info){
+		.stream_name = "OBS Studio",
+		.stream_properties = pw_properties_new(PW_KEY_MEDIA_TYPE, "Video", PW_KEY_MEDIA_CATEGORY, "Capture",
+						       PW_KEY_MEDIA_ROLE, "Screen", NULL),
+		.screencast =
+			{
+				.cursor_visible = capture->cursor_visible,
+			},
+	};
+
+	capture->obs_pw_stream =
+		obs_pipewire_connect_stream(capture->obs_pw, capture->source, capture->pipewire_node, &connect_info);
+}
+
